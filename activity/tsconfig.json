{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "server",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["server/**/*.ts"],
  "exclude": ["client", "node_modules"]
}

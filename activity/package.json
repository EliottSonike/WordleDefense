{
  "name": "tower-defense-activity",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node server/index.ts",
    "dev:client": "vite client --port 5173",
    "build": "vite build client --outDir ../server/dist",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^1.3.0",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  }
}
